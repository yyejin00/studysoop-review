{
  "name": "study-soop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:migrate": "dotenv -e ./back/env/.env.development -- npx prisma migrate dev --schema ./back/prisma/schema.prisma",
    "prisma:studio": "dotenv -e ./back/env/.env.development -- npx prisma studio",
    "prisma:generate": "dotenv -e ./back/env/.env.development -- npx prisma generate",
    "seed": "node --env-file=./back/env/.env.development scripts/seed.js",
    "dev:api": "nodemon --env-file=./back/env/.env.development src/server.js",
    "prod": "node --env-file=/env/.env.production src/server.js"
  },
    "prisma": {
    "schema": "back/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "express": "^5.2.1",
    "next": "16.2.0",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0"
  }
}
